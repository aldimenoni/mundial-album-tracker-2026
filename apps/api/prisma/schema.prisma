generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(uuid())
  name                 String              @unique
  stickers             UserSticker[]
  exchangesFrom        ExchangeProposal[]  @relation("ExchangesFrom")
  exchangesTo          ExchangeProposal[]  @relation("ExchangesTo")
  lastAlbumActivityAt  DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model Sticker {
  id         String        @id @default(uuid())
  code       String        @unique
  number     Int?
  team       String?
  playerName String?
  type       StickerType   @default(STANDARD)
  section    String?
  orderIndex Int
  users      UserSticker[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([orderIndex])
  @@index([team])
  @@index([type])
}

model UserSticker {
  id               String   @id @default(uuid())
  userId           String
  stickerId        String
  quantityOwned    Int      @default(0)
  quantityRepeated Int      @default(0)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sticker          Sticker  @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  updatedAt        DateTime @updatedAt

  @@unique([userId, stickerId])
  @@index([userId])
  @@index([stickerId])
  @@index([userId, updatedAt])
}

enum StickerType {
  STANDARD
  COCA_COLA
  SPECIAL
}

enum ExchangeType {
  DIRECT
  MULTIPLE
  PARTIAL
  PENDING
  INFO_INSUFFICIENT
  NOT_AVAILABLE
}

enum ExchangeStatus {
  DRAFT
  PROPOSED
  ACCEPTED
  PENDING_SETTLEMENT
  COMPLETED
  CANCELLED
}

model ExchangeProposal {
  id                   String         @id @default(uuid())
  fromUserId           String
  toUserId             String
  status               ExchangeStatus @default(DRAFT)
  type                 ExchangeType
  stickersGivenByMe    String[]
  stickersGivenByOther String[]
  pendingCountForMe    Int            @default(0)
  pendingCountForOther Int            @default(0)
  notes                String?
  fromUser             User           @relation("ExchangesFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser               User           @relation("ExchangesTo", fields: [toUserId], references: [id], onDelete: Cascade)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
}
