{
  "name": "@mundial-album/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "prisma generate && tsx watch src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "prisma db seed",
    "seed:exchange-demo": "tsx prisma/seed-exchange-demo.ts",
    "seed:exchange-many-demo": "tsx prisma/seed-exchange-many-demo.ts",
    "seed:exchange-partial-demo": "tsx prisma/seed-exchange-partial-demo.ts",
    "cleanup:test-users": "tsx prisma/cleanup-test-users.ts",
    "start": "node dist/server.js",
    "test": "tsx --test src/modules/exchanges/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mundial-album/shared": "0.1.0",
    "@prisma/client": "^6.19.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
